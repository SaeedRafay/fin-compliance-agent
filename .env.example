# FinComplianceAgent — Environment Variables
# Copy this file to .env and fill in your values

# Required: Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Demo mode: set to true to bypass the Anthropic API and use pre-built mock data
# Useful for testing, demos, or when API credits are unavailable
DEMO_MODE=false

# Optional: Override default model (default: claude-opus-4-5)
# ANTHROPIC_MODEL=claude-opus-4-5

# Optional: Streamlit server config
# STREAMLIT_PORT=8501
